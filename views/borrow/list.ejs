<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Book</th>
                    <th>User</th>
                    <th>Borrow Date</th>
                    <th>Due Date</th>
                    <th>Return Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% records.forEach(record => { %>
                    <tr>
                        <td><%= record.book_title %></td>
                        <td><%= record.user_name %></td>
                        <td><%= new Date(record.borrow_date).toLocaleDateString() %></td>
                        <td><%= new Date(record.due_date).toLocaleDateString() %></td>
                        <td><%= record.return_date ? new Date(record.return_date).toLocaleDateString() : '-' %></td>
                        <td>
                            <span class="badge <%= 
                                record.status === 'approved' ? 'bg-primary' : 
                                record.status === 'returned' ? 'bg-success' : 
                                record.status === 'pending' ? 'bg-warning' : 'bg-danger' 
                            %>">
                                <%= record.status %>
                            </span>
                        </td>
                        <td>
                            <% if ((user.role === 'admin' || user.role === 'librarian') && record.status === 'pending') { %>
                                <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#approveModal<%= record.id %>">
                                    Approve
                                </button>

                                <!-- Approve Modal -->
                                <div class="modal fade" id="approveModal<%= record.id %>" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Approve Borrow Request</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form action="/borrow/approve/<%= record.id %>" method="POST">
                                                <div class="modal-body">
                                                    <p>Book: <strong><%= record.book_title %></strong></p>
                                                    <p>User: <strong><%= record.user_name %></strong></p>
                                                    <div class="mb-3">
                                                        <label class="form-label">Set Due Date</label>
                                                        <input type="date" class="form-control" name="due_date" value="<%= new Date(record.due_date).toISOString().split('T')[0] %>" required>
                                                        <div class="form-text">Default is 14 days from request.</div>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-success">Confirm Approval</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                            <% if ((user.role === 'admin' || user.role === 'librarian') && record.status === 'approved') { %>
                                <form action="/borrow/return/<%= record.id %>" method="POST" class="d-inline">
                                    <button class="btn btn-sm btn-info text-white">Return</button>
                                </form>
                                <% if (user.role === 'admin') { %>
                                    <button class="btn btn-sm btn-outline-secondary ms-1" data-bs-toggle="modal" data-bs-target="#editDueDateModal<%= record.id %>">
                                        <i class="fas fa-calendar-edit"></i>
                                    </button>

                                    <!-- Edit Due Date Modal (Admin Only) -->
                                    <div class="modal fade" id="editDueDateModal<%= record.id %>" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Edit Due Date</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <form action="/borrow/update-due-date/<%= record.id %>" method="POST">
                                                    <div class="modal-body">
                                                        <p>Book: <strong><%= record.book_title %></strong></p>
                                                        <p>Current Due Date: <strong><%= new Date(record.due_date).toLocaleDateString() %></strong></p>
                                                        <div class="mb-3">
                                                            <label class="form-label">New Due Date</label>
                                                            <input type="date" class="form-control" name="due_date" value="<%= new Date(record.due_date).toISOString().split('T')[0] %>" required>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-primary">Save Changes</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                <% } %>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
                <% if (records.length === 0) { %>
                    <tr>
                        <td colspan="7" class="text-center">No records found</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
