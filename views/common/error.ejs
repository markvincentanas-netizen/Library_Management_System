<div class="row justify-content-center mt-5">
    <div class="col-md-8 text-center">
        <div class="card shadow-sm border-danger">
            <div class="card-body py-5">
                <i class="fas fa-exclamation-triangle text-danger fs-1 mb-4"></i>
                <h1 class="display-5 mb-3">System Error</h1>
                <p class="lead text-muted mb-4"><%= message %></p>
                
                <% if (error && error.stack) { %>
                    <div class="text-start mt-4">
                        <pre class="bg-light p-3 rounded small"><code><%= error.stack %></code></pre>
                    </div>
                <% } %>

                <div class="mt-4">
                    <a href="javascript:history.back()" class="btn btn-outline-primary me-2">
                        <i class="fas fa-arrow-left me-2"></i>Go Back
                    </a>
                    <a href="/" class="btn btn-primary">
                        <i class="fas fa-home me-2"></i>Home Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
