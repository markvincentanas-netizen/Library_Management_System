<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">System Settings</h5>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <div>
                            <h6 class="mb-0">Notifications</h6>
                            <small class="text-muted">Receive email alerts for overdue books.</small>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <div>
                            <h6 class="mb-0">Two-Factor Authentication</h6>
                            <small class="text-muted">Secure your account with 2FA.</small>
                        </div>
                        <button class="btn btn-sm btn-outline-primary">Enable</button>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <div>
                            <h6 class="mb-0">Theme Mode</h6>
                            <small class="text-muted">Switch between light and dark mode.</small>
                        </div>
                        <select class="form-select form-select-sm w-auto">
                            <option>Light Mode</option>
                            <option>Dark Mode</option>
                            <option>System Default</option>
                        </select>
                    </div>
                </div>
                <hr>
                <div class="text-center mt-3">
                    <p class="text-muted small">LMS Version 1.0.0</p>
                </div>
            </div>
        </div>
    </div>
</div>
