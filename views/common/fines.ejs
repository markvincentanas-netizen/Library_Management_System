<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Book</th>
                    <th>User</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% fines.forEach(fine => { %>
                    <tr>
                        <td><%= fine.book_title %></td>
                        <td><%= fine.user_name %></td>
                        <td>$<%= fine.amount %></td>
                        <td>
                            <span class="badge <%= fine.status === 'paid' ? 'bg-success' : 'bg-danger' %>">
                                <%= fine.status %>
                            </span>
                        </td>
                        <td>
                            <% if (user.role === 'admin' && fine.status === 'unpaid') { %>
                                <form action="/fines/pay/<%= fine.id %>" method="POST" class="d-inline">
                                    <button class="btn btn-sm btn-success">Mark as Paid</button>
                                </form>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
                <% if (fines.length === 0) { %>
                    <tr><td colspan="5" class="text-center">No fines found</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
