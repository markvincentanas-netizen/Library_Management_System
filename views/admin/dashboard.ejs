<div class="row g-3 my-2">
    <div class="col-md-3">
        <div class="p-3 bg-white shadow-sm d-flex justify-content-around align-items-center rounded">
            <div>
                <h3 class="fs-2"><%= stats.books %></h3>
                <p class="fs-5">Total Books</p>
            </div>
            <i class="fas fa-book fs-1 primary-text border rounded-full secondary-bg p-3"></i>
        </div>
    </div>

    <div class="col-md-3">
        <div class="p-3 bg-white shadow-sm d-flex justify-content-around align-items-center rounded">
            <div>
                <h3 class="fs-2"><%= stats.users %></h3>
                <p class="fs-5">Total Users</p>
            </div>
            <i class="fas fa-users fs-1 primary-text border rounded-full secondary-bg p-3"></i>
        </div>
    </div>

    <div class="col-md-3">
        <div class="p-3 bg-white shadow-sm d-flex justify-content-around align-items-center rounded">
            <div>
                <h3 class="fs-2"><%= stats.borrows %></h3>
                <p class="fs-5">Active Borrows</p>
            </div>
            <i class="fas fa-exchange-alt fs-1 primary-text border rounded-full secondary-bg p-3"></i>
        </div>
    </div>

    <div class="col-md-3">
        <div class="p-3 bg-white shadow-sm d-flex justify-content-around align-items-center rounded">
            <div>
                <h3 class="fs-2 text-danger"><%= stats.overdue %></h3>
                <p class="fs-5">Overdue Books</p>
            </div>
            <i class="fas fa-exclamation-triangle fs-1 text-danger border rounded-full bg-light p-3"></i>
        </div>
    </div>
</div>

<div class="row my-5">
    <h3 class="fs-4 mb-3">Recent Activities</h3>
    <div class="col">
        <table class="table bg-white rounded shadow-sm  table-hover">
            <thead>
                <tr>
                    <th scope="col" width="50">#</th>
                    <th scope="col">Activity</th>
                    <th scope="col">User</th>
                    <th scope="col">Date</th>
                </tr>
            </thead>
            <tbody>
                <% if (activities && activities.length > 0) { %>
                    <% activities.forEach((activity, index) => { %>
                        <tr>
                            <th scope="row"><%= index + 1 %></th>
                            <td><%= activity.activity %></td>
                            <td><%= activity.user_name || 'System' %></td>
                            <td>
                                <% 
                                    const date = new Date(activity.created_at);
                                    const now = new Date();
                                    const diff = now - date;
                                    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                                    if (days === 0) { %>
                                        Today
                                    <% } else if (days === 1) { %>
                                        Yesterday
                                    <% } else { %>
                                        <%= date.toLocaleDateString() %>
                                    <% }
                                %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="text-center">No recent activities found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
