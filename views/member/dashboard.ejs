<div class="row g-3 my-2">
    <div class="col-md-4">
        <div class="p-3 bg-white shadow-sm d-flex justify-content-around align-items-center rounded">
            <div>
                <h3 class="fs-2"><%= stats.borrows %></h3>
                <p class="fs-5">My Borrows</p>
            </div>
            <i class="fas fa-book fs-1 primary-text border rounded-full secondary-bg p-3"></i>
        </div>
    </div>

    <div class="col-md-4">
        <div class="p-3 bg-white shadow-sm d-flex justify-content-around align-items-center rounded">
            <div>
                <h3 class="fs-2 text-warning"><%= stats.pending %></h3>
                <p class="fs-5">Pending Requests</p>
            </div>
            <i class="fas fa-clock fs-1 text-warning border rounded-full bg-light p-3"></i>
        </div>
    </div>

    <div class="col-md-4">
        <div class="p-3 bg-white shadow-sm d-flex justify-content-around align-items-center rounded">
            <div>
                <h3 class="fs-2 text-danger"><%= stats.overdue %></h3>
                <p class="fs-5">Overdue</p>
            </div>
            <i class="fas fa-exclamation-circle fs-1 text-danger border rounded-full bg-light p-3"></i>
        </div>
    </div>
</div>

<div class="row my-5">
    <h3 class="fs-4 mb-3">Welcome to your Library!</h3>
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">Need a book?</h5>
                <p class="card-text">Search our collection and request a book to borrow.</p>
                <a href="/member/browse" class="btn btn-primary">Browse Collection</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <h5 class="card-title">My Profile</h5>
                <i class="fas fa-user-circle fs-1 my-3 text-secondary"></i>
                <p class="card-text">Update your personal information.</p>
                <a href="/profile" class="btn btn-outline-primary btn-sm">Edit Profile</a>
            </div>
        </div>
    </div>
</div>
